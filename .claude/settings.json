{
  "defaultMode": "acceptEdits",
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1"
  },
  "sandbox": {
    "enabled": true,
    "autoAllowBashIfSandboxed": true,
    "network": {
      "allowedDomains": [
        "pub.dev",
        "github.com",
        "supabase.co",
        "firebasestorage.googleapis.com",
        "fonts.googleapis.com",
        "api.flutter.dev",
        "api.stripe.com",
        "api.gocardless.com",
        "r2.cloudflarestorage.com"
      ]
    }
  },
  "permissions": {
    "allow": [
      "Bash(flutter *)",
      "Bash(dart *)",
      "Bash(git add *)",
      "Bash(git commit *)",
      "Bash(git push origin *)",
      "Bash(npm run *)",
      "Bash(bun *)",
      "Bash(supabase *)",
      "Bash(osascript -e 'display notification*')"
    ],
    "deny": [
      "Bash(rm -rf *)",
      "Bash(git push --force *)",
      "Bash(git push -f *)",
      "Bash(flutter pub add *)",
      "Bash(dart pub add *)",
      "Bash(pub global activate *)",
      "Bash(osascript * message *)",
      "Bash(osascript * Messages *)",
      "Bash(mail *)",
      "Bash(sendmail *)",
      "Bash(curl * contacts *)",
      "Bash(curl * addressbook *)",
      "Bash(python * smtplib *)",
      "Bash(open * mailto:*)"
    ]
  },
  "hooks": {
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash /Users/almashomefolder/.claude/hooks/juku-verify.sh"
          }
        ]
      }
    ],
    "StopFailure": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "echo \"$(date): Claude stopped with failure in $CLAUDE_PROJECT_DIR\" >> /Users/almashomefolder/.claude/failure-log.txt && osascript -e 'display notification \"Claude stopped with an error — check terminal\" with title \"Juku Build ❌\" sound name \"Basso\"'"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "cd /Users/almashomefolder/Documents/Claude/Projects/Juku-Flutter && export PATH=\"/Users/almashomefolder/development/flutter/bin:$PATH\" && flutter analyze --no-pub 2>&1 | tail -5 &"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "CMD=$(echo \"$CLAUDE_TOOL_INPUT\" | jq -r '.tool_input.command // empty' 2>/dev/null); if echo \"$CMD\" | grep -qE 'push.*--force|push.*-f[^l]'; then echo '[BLOCKED] Force push to main is not allowed.' >&2; exit 2; fi; if echo \"$CMD\" | grep -qE 'flutter pub add|dart pub add|pub global activate'; then echo '🚫 Package install requires human approval via Dispatch.' >&2; exit 2; fi"
          }
        ]
      }
    ]
  }
}
